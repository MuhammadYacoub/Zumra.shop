# Environment Configuration for Zumra.shop (زُمرة)
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DB_PATH=./scripts/zumra.sqlite

# Security & Session
JWT_SECRET=zumra_super_secret_jwt_key_2026_change_in_production
JWT_EXPIRES_IN=1d
REDIS_URL=redis://localhost:6379

# Telemetry & Logging
LOG_LEVEL=info
CORRELATION_HEADER=x-correlation-id

# Wholesale Market Default Settings
DEFAULT_MARKET_ZONE=EL_ATABA
DEFAULT_CURRENCY=EGP
